# Copy to .env and fill in. Loaded by docker-compose; for local runs, export these.

# Upstream provider keys (leave blank to use only the mock provider / vLLM)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Self-hosted vLLM / TGI server
VLLM_URL=http://localhost:8000/v1
VLLM_API_KEY=

# Redis (for cross-replica cache + distributed rate limiting)
REDIS_URL=redis://localhost:6379/0

# Demo API key when auth is enabled
KVGATE_DEMO_KEY=sk-demo-local
